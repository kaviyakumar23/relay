# --- Slack (dev app from manifest.dev.yaml — Socket Mode) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# App-level token with connections:write — presence of this switches the app to Socket Mode
SLACK_APP_TOKEN=xapp-...

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: dedupe embeddings (text-embedding-3-small). Absent -> pg_trgm fallback.
OPENAI_API_KEY=

# --- Infra (docker compose up -d) ---
DATABASE_URL=postgres://relay:relay@localhost:5432/relay
REDIS_URL=redis://localhost:6379

# --- App ---
PORT=3000
LOG_LEVEL=debug
# AES-256-GCM key for contact_vault, 64 hex chars. Generate: openssl rand -hex 32
CONTACT_VAULT_KEY=
# Demo SLA compression (1 = real time; 0.02 = 45min -> ~54s). Labeled in #judges-start-here.
SLA_MULTIPLIER=1
